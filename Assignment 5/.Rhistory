library(dplyr)
library(ggplot2)
library(fixest)
install.packages("fixest")
library(fixest)
library(modelsummary)
df=read.csv("https://raw.githubusercontent.com/franvillamil/AQM2/refs/heads/master/datasets/presidential_approval/presidential_approval.csv")
#--------
lengh
#--------
summary(df$PresApprov)
summary(df$UnemPct)
df_sub=df %>%
filter(State %in%c("California","Texas","NewYork"))
ggplot(df,aes(x=Year,y=PresApprov,colour = State)++
geom_line()+
theme_minimal())
ggplot(df,aes(x=Year,y=PresApprov,colour = State)+
geom_line()+
theme_minimal())
ggplot(df,aes(x=Year,y=PresApprov,colour = State))+
geom_line()+
theme_minimal()
ggplot(df,aes(x=Year,y=PresApprov,colour = State))+
geom_point(alpha=0.1)+
theme_minimal()+
theme(legend.position = "none")
ggplot(df,aes(x=Year,y=PresApprov,colour = State))+
geom_line()+
theme(legend.position = "none")+
theme_minimal()
#---------
m_pooled=lm(PresApprov~UnemPct, data = df)
summary(m_pooled)
m_pooled2=lm(PresApprov~UnemPct+South, data=df)
modelsummary(list(m_pooled,m_pooled2))
library(gt)
modelsummary(list(m_pooled,m_pooled2),
stars = TRUE,output = gt)
modelsummary(list(m_pooled,m_pooled2),
stars = TRUE,output = "gt")
#
#--------
m_fe=feols(PresApprov~UnemPct | State, data=df)
summary(lm(PresApprov~UnemPct+factor(State), data = df))
summary(m_fe)
modelsummary(list("Model 1"=m_pooled,"Model 2"=m_pooled2),
stars = TRUE,output = "gt")
OLS=summary(lm(PresApprov~UnemPct+factor(State), data = df)) #Normal OLS using factors
#Here Alabama is the reference category
summary(OLS)
modelsummary(
list("Pooled OLS"= m_pooled, "State FE"=m_fe),
vcov = -State,
stars = TRUE,
gof_map = c("r.squared", "noobs")
)
modelsummary(
list("Pooled OLS"= m_pooled, "State FE"=m_fe),
vcov = ~State,
stars = TRUE,
gof_map = c("r.squared", "noobs")
)
modelsummary(
list("Pooled OLS"= m_pooled,"Pooled OLS +Control"=m_pooled2, "State FE"=m_fe),
vcov = ~State,
stars = TRUE,
gof_map = c("r.squared", "noobs")
)
#-----------------
m_twfe=feols(PresApprov~UnemPct | State+Year,
data=df)
modelsummary(
list("Pooled OLS"= m_pooled,"Pooled OLS +Control"=m_pooled2, "State FE"=m_fe, "State and Year FE"=m_twfe),
vcov = ~State,
stars = TRUE,
gof_map = c("r.squared", "noobs")
)
modelsummary(
list("Pooled OLS"= m_pooled,"Pooled OLS +Control"=m_pooled2, "State FE"=m_fe),
vcov = ~State,
stars = TRUE,
gof_map = c("r.squared", "nobs")
)
modelsummary(
list("Pooled OLS"= m_pooled,"Pooled OLS +Control"=m_pooled2, "State FE"=m_fe, "State and Year FE"=m_twfe),
vcov = ~State,
stars = TRUE,
gof_map = c("r.squared", "nobs")
)
