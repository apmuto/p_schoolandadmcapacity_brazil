prop_table <- dataset %>%
count(h1bvis.supp, name = "h1b_n") %>%
mutate(h1b_prop = h1b_n / sum(h1b_n)) %>%
full_join(
dataset %>%
count(indimm.supp, name = "ind_n") %>%
mutate(indimm_prop = ind_n / sum(ind_n)),
by = c("h1bvis.supp" = "indimm.supp")
) %>%
rename(level = h1bvis.supp)
